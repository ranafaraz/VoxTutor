# VoxTutor configuration (all optional; defaults shown). The benchmark is fully offline:
# numpy only, no acoustic model, no audio downloads, no API keys.

# Which scorer to run: random | naive | aligned | normalized | gop
VOXTUTOR_METHOD=gop

# Distortion regime: clean (control) | warped (speaking-rate) | noisy (channel noise)
VOXTUTOR_REGIME=clean

# Ground-truth labels: real | scrambled (scrambled is the chance-level sanity null)
VOXTUTOR_LABELS=real

# Number of utterances pooled per (method, regime, seed)
VOXTUTOR_SAMPLES=40

# Random seed (deterministic; salted np.random.default_rng)
VOXTUTOR_SEED=0

# Backend: numpy (default) | scipy (optional cross-check; needs the [scipy] extra)
VOXTUTOR_BACKEND=numpy
